# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# data.go.kr (공공데이터포털)
# 계정당 인증키 1개. 각 API에 "활용신청"만 추가로 하면 같은 키로 다 사용 가능.
# DATA_GO_KR_KEY 하나만 넣으면 모든 위젯에 공유됨.
DATA_GO_KR_KEY=

# (선택) 서비스별 키를 다르게 쓰고 싶을 때만 override
# 비어있으면 DATA_GO_KR_KEY로 폴백
KMA_API_KEY=
AIRKOREA_API_KEY=
EMERGENCY_API_KEY=
MFDS_API_KEY=
