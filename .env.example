# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# data.go.kr (공공데이터포털)
# 계정당 인증키 1개. 각 API에 "활용신청"만 추가로 하면 같은 키로 다 사용 가능.
# DATA_GO_KR_KEY 하나만 넣으면 모든 위젯에 공유됨.
DATA_GO_KR_KEY=

# (선택) 서비스별 키를 다르게 쓰고 싶을 때만 override
# 비어있으면 DATA_GO_KR_KEY로 폴백
KMA_API_KEY=
AIRKOREA_API_KEY=
EMERGENCY_API_KEY=

# 식품안전나라 (foodsafetykorea.go.kr) — data.go.kr와 별도 시스템.
# 식품 리콜 위젯용. https://www.foodsafetykorea.go.kr 에서 별도 가입 + 인증키 발급.
# 없으면 위젯이 mock으로 폴백.
FOODSAFETY_API_KEY=

# 정보나루 (data4library.kr) — 공공도서관 통합 검색 + 도서 보유 검색.
# data.go.kr와 별개 시스템이지만 통합 키도 동작할 수 있음. 우선 LIBRARY_API_KEY,
# 없으면 DATA_GO_KR_KEY로 폴백. 둘 다 없으면 mock.
LIBRARY_API_KEY=

# 한국관광공사 TourAPI 4.0 — 관광·전시·축제 위젯용.
# data.go.kr 통합 키 또는 별도 키. 없으면 mock.
TOUR_API_KEY=
